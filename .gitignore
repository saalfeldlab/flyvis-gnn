# Data root config (per-environment, not tracked)
data_paths.json

# Track only config/fly/, ignore all other config subfolders
config/*
!config/fly/

# Only track used flyvis configs (referenced in Notebooks/GNN_Main/GNN_PlotFigure)
config/fly/*
!config/fly/flyvis_noise_free.yaml
!config/fly/flyvis_noise_free_mask_50.yaml
!config/fly/flyvis_noise_005.yaml
!config/fly/flyvis_noise_005_002.yaml
!config/fly/flyvis_noise_005_004.yaml
!config/fly/flyvis_noise_005_006.yaml
!config/fly/flyvis_noise_005_008.yaml
!config/fly/flyvis_noise_005_010.yaml
!config/fly/flyvis_noise_005_INR.yaml
!config/fly/flyvis_noise_005_agentic.yaml
!config/fly/flyvis_noise_005_default.yaml
!config/fly/flyvis_noise_005_mask_50.yaml
!config/fly/flyvis_noise_005_null_edges_pc_100.yaml
!config/fly/flyvis_noise_005_null_edges_pc_200.yaml
!config/fly/flyvis_noise_005_null_edges_pc_400.yaml
!config/fly/flyvis_noise_005_removed_pc_02.yaml
!config/fly/flyvis_noise_005_removed_pc_05.yaml
!config/fly/flyvis_noise_005_removed_pc_10.yaml
!config/fly/flyvis_noise_005_removed_pc_20.yaml
!config/fly/flyvis_noise_05.yaml
!config/fly/flyvis_noise_05_mask_50.yaml

# Data files (large simulation data)
*.npy
*.npz
*.pth
*.backup
paper/
papers/

# Log folder - include models/*.pt and loss_components.pt, exclude everything else
log/**/*
!log/.gitkeep
!log/fly/
!log/fly/**/
!log/fly/**/models/
!log/fly/**/models/*.pt
!log/fly/flyvis_noise_free/loss_components.pt
!log/fly/flyvis_noise_005/loss_components.pt
!log/fly/flyvis_noise_05/loss_components.pt
!log/fly/flyvis_noise_005_INR/loss_components.pt

# Ignore edge_index.pt and mask.pt everywhere (recreated from connectivity)
**/edge_index.pt
**/mask.pt

# graphs_data: include connectivity.pt, exclude generated files
graphs_data/**/*.npy
graphs_data/**/*.backup
graphs_data/**/*.png
graphs_data/**/analysis.log
graphs_data/**/X1.pt
graphs_data/**/X_msg.pt

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/

# IDE
.devcontainer/
.idea/
.vscode/
*.swp
*.swo

# Benchmark / one-off run scripts
run_*.py
test_edge_removal.py
test_null_edges.py
plot_benchmark*.py
plot_edge_removal.py
plot_null_edges_all_metrics.py
plot_two_panel.py
refactor.md

# Code review
flyvis_gnn_code_review*.pdf
code_review_deepmind_v*.py

# LLM exploration (cluster-specific scripts, not tracked)
GNN_LLM.py
INR_LLM.py
src/flyvis_gnn/LLM/cluster.py

# LLM instruction directory — track only the main instruction files
LLM/*
!LLM/instruction_flyvis_noise_free.md
!LLM/instruction_flyvis_noise_005.md
!LLM/instruction_flyvis_noise_05.md

# OS
.DS_Store
Thumbs.db

# Quarto
/.quarto/
_site/
docs/
*.quarto_ipynb
*_files/
!docs/**/*_files/
*.ipynb

**/*.quarto_ipynb

# Assets (LFS-tracked PNGs/HTMLs)
assets/*.png
assets/*.html
